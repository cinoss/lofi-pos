{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LoFi POS",
  "version": "0.0.1",
  "identifier": "com.lofi-pos.cashier",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      { "title": "LoFi POS", "width": 1280, "height": 800, "resizable": true }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"],
    "resources": {
      "../../admin/dist": "admin/dist"
    }
  }
}
